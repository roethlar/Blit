# Rust build artifacts
/target/
**/target/
# Cargo.lock IS tracked (audit-7, owner decision 2026-05-23): this
# workspace ships binaries (blit, blit-daemon, blit-tui,
# blit-prometheus-bridge), so the lockfile is committed for reproducible
# builds per Rust's binary-crate convention.
agentcomms/
agentcomms/**

# Rust specific
*.rs.bk
*.pdb

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Claude Code specific — commit only settings.json + commands/; ignore everything
# else under .claude/ (personal settings.local.json AND the stale worktrees/ checkout).
.claude/*
!.claude/settings.json
!.claude/commands/

# Debug and test artifacts
*.log
*.tmp
debug/
tmp/
logs/

# OS specific
Thumbs.db
# macOS AppleDouble resource-fork sidecars (created when copying onto
# some filesystems); never belong in the repo.
._*

# Local benchmark/diagnostic results — not for the repo
testing/

# Session export files (one-shot conversation transcripts, ~MB each)
[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]-*.txt
